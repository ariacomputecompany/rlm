{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ariacomputecompany/rlm/schemas/agent-config.v1.schema.json",
  "title": "RLM Agent Config v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol",
    "mesh_id",
    "session_id",
    "agent_id",
    "role",
    "workspace_root",
    "execution_boundary",
    "accelerator",
    "jets_namespace",
    "jets_inbox",
    "coordinator_alias"
  ],
  "properties": {
    "protocol": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "const": "rlm" },
        "version": { "const": 1 }
      }
    },
    "mesh_id": { "type": "string", "minLength": 1 },
    "session_id": { "type": "string", "minLength": 1 },
    "agent_id": { "type": "string", "minLength": 1 },
    "role": { "type": "string", "enum": ["coordinator", "worker"] },
    "workspace_root": { "type": "string", "minLength": 1 },
    "execution_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repl_scope",
        "context_scope",
        "admitted_context_roots"
      ],
      "properties": {
        "repl_scope": {
          "type": "string",
          "const": "environment_only"
        },
        "context_scope": {
          "type": "string",
          "const": "workspace_only"
        },
        "admitted_context_roots": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "accelerator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gpu_passthrough_supported",
        "gpu_requested",
        "gpu_attached"
      ],
      "properties": {
        "gpu_passthrough_supported": {
          "type": "boolean"
        },
        "gpu_requested": {
          "type": "boolean"
        },
        "gpu_attached": {
          "type": "boolean"
        },
        "gpu_provider": {
          "type": "string",
          "minLength": 1
        },
        "device_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "jets_namespace": { "type": "string", "minLength": 1 },
    "jets_inbox": { "type": "string", "minLength": 1 },
    "jets_dlq": { "type": "string", "minLength": 1 },
    "coordinator_alias": { "type": "string", "minLength": 1 },
    "provider_env_allowlist": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
