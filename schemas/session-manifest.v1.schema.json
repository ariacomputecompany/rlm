{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ariacomputecompany/rlm/schemas/session-manifest.v1.schema.json",
  "title": "RLM Session Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol",
    "session_id",
    "mode",
    "container_id",
    "workspace_root",
    "state_root",
    "execution_boundary",
    "accelerator",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "protocol": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "const": "rlm" },
        "version": { "const": 1 }
      }
    },
    "session_id": { "type": "string", "minLength": 1 },
    "session_name": { "type": "string", "minLength": 1 },
    "mode": {
      "type": "string",
      "enum": ["single_agent", "mesh_coordinator", "mesh_worker"]
    },
    "container_id": { "type": "string", "minLength": 1 },
    "workspace_root": { "type": "string", "minLength": 1 },
    "state_root": { "type": "string", "minLength": 1 },
    "execution_boundary": {
      "$ref": "#/$defs/execution_boundary"
    },
    "accelerator": {
      "$ref": "#/$defs/accelerator"
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "active_trajectory_id": { "type": "string", "minLength": 1 },
    "mesh_id": { "type": "string", "minLength": 1 },
    "metadata": { "type": "object" }
  },
  "$defs": {
    "execution_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repl_scope",
        "context_scope",
        "admitted_context_roots"
      ],
      "properties": {
        "repl_scope": {
          "type": "string",
          "const": "environment_only"
        },
        "context_scope": {
          "type": "string",
          "const": "workspace_only"
        },
        "admitted_context_roots": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "accelerator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gpu_passthrough_supported",
        "gpu_requested",
        "gpu_attached"
      ],
      "properties": {
        "gpu_passthrough_supported": {
          "type": "boolean"
        },
        "gpu_requested": {
          "type": "boolean"
        },
        "gpu_attached": {
          "type": "boolean"
        },
        "gpu_provider": {
          "type": "string",
          "minLength": 1
        },
        "device_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
