{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ariacomputecompany/rlm/schemas/mesh-manifest.v1.schema.json",
  "title": "RLM Mesh Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol",
    "mesh_id",
    "session_id",
    "workspace_root",
    "volume_name",
    "coordinator",
    "workers",
    "jets_namespace",
    "created_at"
  ],
  "properties": {
    "protocol": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "const": "rlm" },
        "version": { "const": 1 }
      }
    },
    "mesh_id": { "type": "string", "minLength": 1 },
    "session_id": { "type": "string", "minLength": 1 },
    "workspace_root": { "type": "string", "minLength": 1 },
    "volume_name": { "type": "string", "minLength": 1 },
    "jets_namespace": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "coordinator": {
      "$ref": "#/$defs/agent"
    },
    "workers": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/agent" }
    }
  },
  "$defs": {
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "agent_id",
        "role",
        "container_id",
        "container_name",
        "dns_alias",
        "jets_inbox"
      ],
      "properties": {
        "agent_id": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "enum": ["coordinator", "worker"] },
        "container_id": { "type": "string", "minLength": 1 },
        "container_name": { "type": "string", "minLength": 1 },
        "dns_alias": { "type": "string", "minLength": 1 },
        "jets_inbox": { "type": "string", "minLength": 1 }
      }
    }
  }
}
